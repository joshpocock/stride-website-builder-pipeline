# stride-website-builder-pipeline .env template
# Copy this file to your project root as `.env` and fill in the values.
# The skill reads these at runtime; missing values will be flagged in the
# preflight check (Phase 0) but the skill will still run on what's available.

# ──────────────────────────────────────────────────────────────────
# AI GENERATION (at least one required)
# ──────────────────────────────────────────────────────────────────

# Kie.ai — Fastest NanoBanana 2 + Kling 3.0 (~38s per image, ~$0.36/video)
# Default image provider for hero pair generation.
# Get: https://kie.ai → Dashboard → API Keys
KIE_AI_API_KEY=

# Wavespeed AI — Required for Gemini 3 Pro Image (4K heroes, $0.025/img) and
# Nano Banana Pro Edit Multi (locked-pair matching pass). If set, the skill
# prefers Wavespeed for the hero pair because Gemini 3 Pro Image renders at 4K
# natively, cheaper per image than Nano Banana Pro on Kie.ai, and is the
# newest model in the Gemini family. If unset, the skill falls back to
# Kie.ai Nano Banana Pro at 2K.
# Get: https://wavespeed.ai → Dashboard → API Keys
WAVESPEED_API_KEY=

# Higgsfield.ai — Unified platform (NanoBanana, Kling, Cinema Studio, Flux, Shots)
# Get: https://higgsfield.ai → Settings → API
# Pro plan ~$30 for 600 credits
HIGGSFIELD_API_KEY=

# Google AI Studio — FREE NanoBanana 2 access (slower but $0)
# Get: https://aistudio.google.com → API Keys
GOOGLE_AI_STUDIO_KEY=

# Gemini API — Required for cc-nano-banana skill
# Get: https://aistudio.google.com → API Keys (same as above, different use)
GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────────────
# BRAND EXTRACTION
# ──────────────────────────────────────────────────────────────────

# Firecrawl — Extract brand identity from any URL (free tier: 500 scrapes/mo)
# Get: https://firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=

# ──────────────────────────────────────────────────────────────────
# DEPLOYMENT (optional — needed if you pick a deploy target)
# ──────────────────────────────────────────────────────────────────

# GitHub — For code storage + Vercel auto-deploy
# Get: gh auth login, or https://github.com/settings/tokens
GITHUB_TOKEN=

# Vercel — Production hosting + auto-deploy
# Get: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Netlify — Alternative free hosting
# Get: https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=

# Cloudflare — Pages hosting (alternative)
# Get: https://dash.cloudflare.com → API Tokens
CLOUDFLARE_API_TOKEN=

# ──────────────────────────────────────────────────────────────────
# OPTIONAL COMPONENT SOURCES
# ──────────────────────────────────────────────────────────────────

# 21st.dev Magic MCP — AI-pickable component library
# Get: https://21st.dev/magic/console
# NOTE: 21st.dev passes the key as a CLI arg literally named `API_KEY`,
# not as a standard env var. We store it here as TWENTY_FIRST_API_KEY for
# our own reference, and the preflight script injects it into the MCP config
# at `.claude/mcp_config.json` when running the install command:
#   npx @21st-dev/cli@latest install claude --api-key $TWENTY_FIRST_API_KEY
TWENTY_FIRST_API_KEY=

# Google Stitch MCP — design-to-code via Google Stitch
# Get: https://stitch.withgoogle.com → Settings → API Key
# NOTE: Direct HTTP transport is BROKEN in Claude Code (issue #41664).
# Use the stdio proxy setup: https://stitch.withgoogle.com/docs/mcp/setup
# Alternative: use Stitch UI's "Copy to Figma" button or HTML/Tailwind export.
STITCH_API_KEY=

# Paper.design MCP — local design tool MCP server
# No env var needed. The server runs locally at http://127.0.0.1:29979/mcp
# when the Paper Desktop app is open with a file. Install in Claude Code via:
#   claude mcp add paper --transport http http://127.0.0.1:29979/mcp --scope user
# Verify with `/mcp` inside Claude Code.
# Docs: https://paper.design/docs/mcp

# ──────────────────────────────────────────────────────────────────
# ANALYTICS (optional, added during SEO pass if set)
# ──────────────────────────────────────────────────────────────────

# Google Analytics 4 — Tracking ID injected into the built site
GA4_MEASUREMENT_ID=

# Plausible Analytics — Privacy-first alternative to GA4
PLAUSIBLE_DOMAIN=

# ──────────────────────────────────────────────────────────────────
# PROJECT METADATA (filled by the skill at scaffold time)
# ──────────────────────────────────────────────────────────────────

PROJECT_NAME=
PROJECT_DOMAIN=
PROJECT_DEPLOY_URL=
